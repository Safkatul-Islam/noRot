{
  "name": "norot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:desktop": "npm run build -w @norot/shared && npm run dev -w @norot/desktop",
    "dev:api": "npm run dev -w @norot/api",
    "build:shared": "npm run build -w packages/shared",
    "build:desktop": "npm run build -w apps/desktop",
    "build": "npm run build:shared && npm run build:desktop"
  },
  "devDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
